{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nekos",
  "version": "1.0.0",
  "identifier": "dev.nekobot.nekos",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nekos by nekobot",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
